# ============================================
# GoNow 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================

# --- 前端变量（VITE_ 前缀，会注入到浏览器） ---

# 高德地图 JS API Key（前端地图渲染）
VITE_AMAP_KEY=your_amap_js_key_here

# 高德地图安全密钥（前端，配置到 index.html 的 window._AMapSecurityConfig）
# VITE_AMAP_SECURITY_CODE=your_amap_security_code_here

# --- 后端变量（Netlify Functions 使用） ---

# 和风天气 API Key（天气数据，免费版每天 1000 次）
# 注册：https://dev.qweather.com
WEATHER_API_KEY=your_weather_api_key_here

# 智谱 AI GLM-4-Flash（AI 对话，完全免费）
# 注册：https://open.bigmodel.cn
ZHIPU_API_KEY=your_zhipu_api_key_here

# DeepSeek V3（AI 对话，完全免费）
# 注册：https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Google Gemini Flash（AI 对话，免费 1500 次/天）
# 注册：https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Claude API（AI 对话备用，需付费）
# 注册：https://console.anthropic.com
ANTHROPIC_API_KEY=your_claude_api_key_here

# --- 可选变量 ---

# 高德 Web Service API Key（后端地理编码/路线规划）
# AMAP_WEB_KEY=your_amap_web_key_here
